	vf.Visible = true
end

local function w(txt, col, obj)
	local l = Instance.new("TextButton")
	l.Size = UDim2.new(1, 0, 0, 18)
	l.BackgroundTransparency = 1
	l.Text = "> " .. txt
	l.TextColor3 = col or Color3.fromRGB(0, 255, 0)
	l.Font = Enum.Font.Code
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.Parent = sc

	if obj and (obj:IsA("LuaSourceContainer")) then
		local lc = 0
		l.MouseButton1Click:Connect(function()
			if tick() - lc < 0.5 then openSource(obj) end
			lc = tick()
		end)
	end
	sc.CanvasPosition = Vector2.new(0, 99999)
end

local function toggleNoclip()
	noclipActive = not noclipActive
	w("NOCLIP: " .. (noclipActive and "ENABLED" or "DISABLED"), noclipActive and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0))
	local char = p.Character
	if not char then return end

	RunService.Stepped:Connect(function()
		if noclipActive and char then
			for _, part in pairs(char:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide = false end
			end
		end
	end)
end

RunService.RenderStepped:Connect(function(dt)
	if noclipActive and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
		local hrp = p.Character.HumanoidRootPart
		local cam = WS.CurrentCamera.CFrame
		local moveDir = Vector3.new(0,0,0)

		if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end

		hrp.Velocity = Vector3.new(0,0,0)
		hrp.CFrame = hrp.CFrame + (moveDir * speed * dt)
	end
end)

ib.FocusLost:Connect(function(e)
	if e and ib.Text ~= "" then
		local cmd = ib.Text:lower()
		if cmd == "noclip" then toggleNoclip() else w("LOCAL: " .. ib.Text, Color3.fromRGB(255, 255, 0)) end
		ib.Text = ""
	end
end)

