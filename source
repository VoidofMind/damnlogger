local function drag(f, h)
	local d, i, m, pos
	h.InputBegan:Connect(function(inpt)
		if inpt.UserInputType == Enum.UserInputType.MouseButton1 then d = true m = inpt.Position pos = f.Position
			inpt.Changed:Connect(function() if inpt.UserInputState == Enum.UserInputState.End then d = false end end)
		end
	end)
	UIS.InputChanged:Connect(function(inpt)
		if d and inpt.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = inpt.Position - m
			f.Position = UDim2.new(pos.X.Scale, pos.X.Offset + delta.X, pos.Y.Scale, pos.Y.Offset + delta.Y)
		end
	end)
end
