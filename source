local function missing(t, f, fallback)
	if type(f) == t then return f end
	return fallback
end

local _decompile = missing("function", decompile)
local _getscriptbytecode = missing("function", getscriptbytecode)
local _request = missing("function", request or http_request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request))

if not _decompile and _getscriptbytecode and _request then
	pcall(function()
		loadstring(game:HttpGet("https://raw.githubusercontent.com/infyiff/backup/refs/heads/main/konstant.lua"))()
		_decompile = missing("function", decompile)
	end)
end

local function getSource(scr)
	if _decompile then
		local ok, src = pcall(_decompile, scr)
		if ok and src and src ~= "" then
			return src:gsub("\0", "\\0")
		end
	end
	if _getscriptbytecode then
		local ok, bytecode = pcall(_getscriptbytecode, scr)
		if ok and bytecode and bytecode ~= "" then
			return "-- [DECOMPILE FAILED - BYTECODE ONLY]"
		end
	end
	return "-- [SOURCE PROTECTED]"
end

