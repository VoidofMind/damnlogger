	scan(SP.StarterPlayerScripts, "SPS")
	scan(SP.StarterCharacterScripts, "SCS")
	pcall(function() scan(SSS, "SSS") end)
	w("--- END ---", Color3.fromRGB(0, 255, 255))
end)

